{
  "name": "youshouldsleep",
  "private": true,
  "version": "0.1.0",
  "description": "FocusGate browser extension for rule-group website boundaries.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 51791",
    "build": "npm run lint && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5180",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "store:assets": "node scripts/export-store-assets.mjs",
    "store:screenshots": "node scripts/capture-store-screenshots.mjs",
    "package:store": "npm run build && node scripts/package-store.mjs",
    "store:cws:upload": "node scripts/cws-api.mjs upload",
    "store:cws:submit": "node scripts/cws-api.mjs submit",
    "store:cws:release": "node scripts/cws-api.mjs release",
    "store:cws:status": "node scripts/cws-api.mjs status",
    "store:cws:set-percentage": "node scripts/cws-api.mjs set-percentage",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.0.277",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
