# Chrome Web Store item/draft ID. The current draft is already known.
CWS_EXTENSION_ID=hgjbamghlljcjckbcibjgknaidedaibi

# Chrome Web Store publisher ID, not the public publisher name.
# Get it from the Chrome Web Store Developer Dashboard account/publisher settings
# or from CWS API URLs after API access is enabled.
CWS_PUBLISHER_ID=

# Preferred automation auth: service account JSON from Google Cloud.
# For GitHub Actions, put the compact one-line JSON in the CWS_SERVICE_ACCOUNT_JSON secret.
CWS_SERVICE_ACCOUNT_JSON=

# Local alternative: path to a downloaded service account key JSON file.
# Do not commit the JSON key file.
CWS_SERVICE_ACCOUNT_FILE=

# OAuth fallback if service accounts are not available.
CWS_CLIENT_ID=
CWS_CLIENT_SECRET=
CWS_REFRESH_TOKEN=

# Optional publish controls.
CWS_PUBLISH_TYPE=DEFAULT_PUBLISH
CWS_BLOCK_ON_WARNINGS=true
CWS_SKIP_REVIEW=false
CWS_DEPLOY_PERCENTAGE=
